loading="lazy"
decoding="async"
alt="Greeting on Disconnect"
class="gallery-image"
data-flex-grow="241"
data-flex-basis="578px"
> &lt;img src="https://heusser.pro/p/teams-call-queues-now-support-greetings-in-exception-handlings-1ye1avs43jps/image-1.png"
